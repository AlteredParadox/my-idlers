APP_NAME=my-idlers
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=my_idlers
DB_USERNAME=my_idlers
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Set to true when serving over HTTPS
SESSION_SECURE_COOKIE=false

# Comma-separated proxy IPs (or *) when behind a reverse proxy
TRUSTED_PROXIES=

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# Registration cap: registration closes once this many users exist (0 = unlimited)
MAX_USERS=1

# Currency conversion rates endpoint (e.g. https://open.er-api.com/v6/latest/USD).
# Leave blank to disable conversion (1:1 fallback).
EXCHANGE_RATES_URL=

# Set to true to seed demo data alongside the core seeders
SEED_DEMO_DATA=false
