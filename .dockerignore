# Secrets — must never enter a build context (git-ignoring .env does not
# keep it out of a local `docker build .`)
.env
.env.*
!.env.example

# VCS and CI internals
.git
.gitattributes
.gitea
.github
.styleci.yml
sonar-project.properties

# Dependencies (installed inside the image / prebuilt into public/)
vendor
node_modules

# Tests and local tooling artifacts
tests
phpunit.xml
phpunit.mysql.xml
coverage.xml
.phpunit.result.cache
webpack.mix.js
package.json
package-lock.json

# Local runtime state — keep the directories (via their .gitignore
# placeholders) but never bake local contents into the image
storage/app/*
!storage/app/.gitignore
!storage/app/public
storage/app/public/*
!storage/app/public/.gitignore
storage/framework/cache/data/*
!storage/framework/cache/data/.gitignore
storage/framework/sessions/*
!storage/framework/sessions/.gitignore
storage/framework/testing/*
!storage/framework/testing/.gitignore
storage/framework/views/*
!storage/framework/views/.gitignore
storage/logs/*
!storage/logs/.gitignore
bootstrap/cache/*
!bootstrap/cache/.gitignore
database/*.sqlite
database/*.sqlite-journal

# Editor/agent local dirs
.idea
.vscode
.claude
